Vagrant.configure("2") do |config|
  config.vm.box = "ubuntu/jammy64"
  config.vm.hostname = "fitness-vm"

  # Private IP for accessing the app
  config.vm.network "private_network", ip: "192.168.56.80"

  # Forward common ports to host for convenience (guest -> host)
  config.vm.network "forwarded_port", guest: 80, host: 8080
  config.vm.network "forwarded_port", guest: 3001, host: 3001

  # Sync the whole repo (fitness-project) into VM
  # Set owner/group and mount options so VM users can install packages and run the app.
  # Note: on Windows ensure `provision.sh` has LF line endings to avoid bash issues.
  config.vm.synced_folder "../../", "/opt/fitness-project", type: "virtualbox", owner: "vagrant", group: "vagrant", mount_options: ["dmode=775,fmode=664"]

  config.vm.provider "virtualbox" do |vb|
    vb.memory = 2048
    vb.cpus = 2
  end

  config.vm.provision "shell", path: "provision.sh"
end
